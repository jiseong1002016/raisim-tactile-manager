<?xml version="1.0"?>
<robot name="tactile_gripper_example">
  <link name="base">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <link name="left_tactile_pad">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.012 0.08 0.14"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.012 0.08 0.14"/>
      </geometry>
    </visual>
  </link>

  <joint name="base_to_left_tactile_pad" type="fixed">
    <parent link="base"/>
    <child link="left_tactile_pad"/>
    <origin xyz="0.02 0 0" rpy="0 0 0"/>
  </joint>

  <link name="right_tactile_pad">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.012 0.08 0.14"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.012 0.08 0.14"/>
      </geometry>
    </visual>
  </link>

  <joint name="base_to_right_tactile_pad" type="fixed">
    <parent link="base"/>
    <child link="right_tactile_pad"/>
    <origin xyz="-0.02 0 0" rpy="0 0 0"/>
  </joint>
</robot>
